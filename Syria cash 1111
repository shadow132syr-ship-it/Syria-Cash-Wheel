<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Syria Cash - Throne Final</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body { 
            background: radial-gradient(circle at center, #1a2a6c 0%, #000000 100%); 
            color: white; font-family: 'Segoe UI', sans-serif; 
            display: flex; flex-direction: column; align-items: center; 
            justify-content: center; height: 100vh; margin: 0; overflow: hidden;
        }

        /* الإطار المعدني للعجلة */
        .wheel-outer-frame {
            position: relative; width: 320px; height: 320px;
            border: 10px solid #2c3e50; border-radius: 50%;
            box-shadow: 0 0 50px rgba(0,0,0,0.9), inset 0 0 20px #000;
        }

        .wheel-body {
            width: 100%; height: 100%; border-radius: 50%;
            transition: transform 6s cubic-bezier(0.1, 0, 0.1, 1);
            will-change: transform;
        }

        canvas { width: 100%; height: 100%; transform: rotate(-90deg); }

        /* الزر الأحمر المتوهج في المنتصف */
        .center-btn {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 55px; height: 55px;
            background: radial-gradient(circle at 30% 30%, #ff4b2b, #8e0000);
            border: 3px solid #1a1a1a; border-radius: 50%; z-index: 10;
            box-shadow: 0 0 20px rgba(255, 75, 43, 0.7);
        }

        /* المؤشر الفضي العلوي */
        .top-pointer {
            position: absolute; top: -15px; left: 50%;
            transform: translateX(-50%); width: 0; height: 0;
            border-left: 18px solid transparent; border-right: 18px solid transparent;
            border-top: 32px solid #ecf0f1; z-index: 20;
        }

        .status-bar { margin-top: 40px; text-align: center; }
        
        .win-label {
            font-size: 20px; color: #f1c40f; font-weight: bold;
            margin-bottom: 20px; height: 30px; text-shadow: 0 0 10px rgba(241, 196, 15, 0.5);
        }

        .spin-action-btn {
            background: rgba(0, 0, 0, 0.7); color: white;
            padding: 12px 40px; border-radius: 30px;
            border: 2px solid #444; font-size: 18px; font-weight: bold;
            cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

    <div class="wheel-outer-frame">
        <div class="top-pointer"></div>
        <div class="center-btn"></div>
        <div class="wheel-body" id="wheel">
            <canvas id="canvas" width="500" height="500"></canvas>
        </div>
    </div>

    <div class="status-bar">
        <div class="win-label" id="msg"></div>
        <button class="spin-action-btn" id="btn">لفّ العجلة الآن 🎰</button>
    </div>

<script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    const wheel = document.getElementById('wheel');
    const btn = document.getElementById('btn');
    const msg = document.getElementById('msg');

    // المبالغ التسعة (من ليرة كاش)
    const prizes = ["100 ليرة", "20 ليرة", "1 ليرة", "حظ أوفر", "50 ليرة", "10 ليرات", "5 ليرات", "7 ليرات", "12 ليرة"];
    const colors = ["#e74c3c", "#f39c12", "#27ae60", "#34495e", "#8e44ad", "#f1c40f", "#2980b9", "#16a085", "#d35400"];

    function draw() {
        const num = prizes.length;
        const arc = 2 * Math.PI / num;
        for(let i=0; i<num; i++) {
            const angle = i * arc;
            ctx.fillStyle = colors[i];
            ctx.beginPath(); ctx.moveTo(250, 250);
            ctx.arc(250, 250, 245, angle, angle + arc); ctx.fill();
            ctx.strokeStyle = "rgba(255,255,255,0.1)"; ctx.lineWidth = 2; ctx.stroke();

            ctx.save(); ctx.translate(250, 250); ctx.rotate(angle + arc / 2);
            ctx.textAlign = "right"; ctx.fillStyle = "white";
            ctx.font = "bold 20px Arial"; ctx.fillText(prizes[i], 230, 10);
            ctx.restore();
        }
    }
    draw();

    let rotation = 0;
    btn.onclick = () => {
        btn.disabled = true;
        msg.innerText = "⏳ جاري التدوير...";
        const spin = Math.floor(Math.random() * 360) + 3600;
        rotation += spin;
        wheel.style.transform = `rotate(${rotation}deg)`;
        setTimeout(() => {
            btn.disabled = false;
            const deg = rotation % 360;
            const idx = Math.floor((360 - deg) / (360 / prizes.length)) % prizes.length;
            msg.innerText = prizes[idx] === "حظ أوفر" ? "😢 حظ أوفر!" : "🎊 مبروك! ربحت " + prizes[idx];
        }, 6000);
    };

    Telegram.WebApp.ready();
</script>
</body>
</html>
